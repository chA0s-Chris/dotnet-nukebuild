# install kubectl
ENV KUBECTL_VERSION="1.35.3"
RUN curl -L https://dl.k8s.io/v${KUBECTL_VERSION}/bin/linux/amd64/kubectl -o kubectl \
    && kubectl_sha512='653d27a9c9184b409d3b0fdff9bd85025cdf14b405acb2787cb9ed43f33adf319e2e5f0d4e448c68f2e8cd5d190620017666f9ce6a5c65308f073493f9a0e748' \
    && echo "$kubectl_sha512 kubectl" | sha512sum -c - \
    && chmod +x kubectl \
    && mv kubectl /usr/bin/kubectl \
    && kubectl 
